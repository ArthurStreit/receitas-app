<?xml version="1.0"?>
<ruleset name="ReceitasApp">
    <description>
        Verificação de qualidade do projeto Receitas App.
    </description>

    <rule ref="PSR12"/>

    <file>app</file>
    <file>routes</file>
    <file>tests</file>

    <exclude-pattern>vendor/*</exclude-pattern>
    <exclude-pattern>storage/*</exclude-pattern>
    <exclude-pattern>bootstrap/cache/*</exclude-pattern>

    <arg name="colors"/>
    <arg value="p"/>
</ruleset>